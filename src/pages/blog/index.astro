---
import Layout from '../../layouts/Layout.astro';
import { getBlogPosts } from '../../lib/contentful';

let posts = [];
try {
  posts = await getBlogPosts();
} catch (e) {
  // Contentful not configured yet
}

// Fallback posts for preview
if (!posts.length) {
  posts = [
    {
      title: 'How to Prevent Frozen Pipes This Winter',
      slug: 'prevent-frozen-pipes',
      excerpt: 'Frozen pipes are one of the most common — and costly — plumbing emergencies in cold climates. Here\'s how to protect your home before temperatures drop.',
      publishedDate: '2024-12-10',
      tags: ['Winter', 'Maintenance', 'DIY Tips'],
    },
    {
      title: 'Tankless vs. Tank Water Heaters: Which Is Right for You?',
      slug: 'tankless-vs-tank-water-heater',
      excerpt: 'We break down the pros, cons, and costs of both water heater types to help you make the best decision for your home and budget.',
      publishedDate: '2024-11-22',
      tags: ['Water Heater', 'Guide', 'Energy Savings'],
    },
    {
      title: '5 Warning Signs Your Sewer Line Needs Attention',
      slug: 'sewer-line-warning-signs',
      excerpt: 'Ignoring sewer line problems can lead to catastrophic — and expensive — failures. Learn the early warning signs before disaster strikes.',
      publishedDate: '2024-11-05',
      tags: ['Sewer', 'Maintenance', 'Emergency'],
    },
    {
      title: 'The Complete Guide to Water Pressure Problems',
      slug: 'water-pressure-problems-guide',
      excerpt: 'Low water pressure can be a minor annoyance or a sign of a serious underlying issue. We walk through every possible cause and solution.',
      publishedDate: '2024-10-18',
      tags: ['Troubleshooting', 'Guide', 'DIY Tips'],
    },
    {
      title: 'When to DIY and When to Call a Plumber',
      slug: 'diy-vs-call-plumber',
      excerpt: 'Some plumbing tasks are safe for homeowners. Others can cause serious damage or code violations. Here\'s how to tell the difference.',
      publishedDate: '2024-10-02',
      tags: ['DIY Tips', 'Guide'],
    },
    {
      title: 'How Often Should You Snake Your Drains?',
      slug: 'how-often-snake-drains',
      excerpt: 'Regular drain maintenance prevents blockages and extends the life of your plumbing. We explain the ideal schedule for every drain in your home.',
      publishedDate: '2024-09-15',
      tags: ['Drain Cleaning', 'Maintenance'],
    },
  ];
}

function formatDate(dateStr: string) {
  return new Date(dateStr).toLocaleDateString('en-US', {
    year: 'numeric', month: 'long', day: 'numeric',
  });
}
---

<Layout
  title="Plumbing Tips & Blog"
  description="Expert plumbing advice, maintenance tips, and DIY guides from the ProFlow team."
>
  <section class="page-header">
    <div class="container">
      <div class="badge">Knowledge Base</div>
      <h1 class="page-title">Plumbing <span>Blog</span></h1>
      <div class="copper-line"></div>
      <p class="page-intro">Expert tips, seasonal guides, and plumbing advice — straight from our licensed technicians.</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      {posts.length > 0 ? (
        <div class="blog-grid">
          {posts.map((post, i) => (
            <article class={`post-card ${i === 0 ? 'post-card--featured' : ''}`}>
              {post.coverImage && (
                <div class="post-image">
                  <img src={post.coverImage.url} alt={post.coverImage.description} loading="lazy" />
                </div>
              )}
              <div class="post-body">
                <div class="post-tags">
                  {post.tags?.map((tag: string) => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
                <h2 class="post-title">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h2>
                <p class="post-excerpt">{post.excerpt}</p>
                <div class="post-footer">
                  <time class="post-date">{formatDate(post.publishedDate)}</time>
                  <a href={`/blog/${post.slug}`} class="read-more">
                    Read Article
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                </div>
              </div>
            </article>
          ))}
        </div>
      ) : (
        <div class="empty-state">
          <div class="empty-icon">✍️</div>
          <h2>No posts yet</h2>
          <p>Add blog posts in Contentful with the <code>blogPost</code> content type to see them here.</p>
        </div>
      )}
    </div>
  </section>
</Layout>

<style>
.page-header {
  padding: 5rem 0 3rem;
  background: var(--navy-mid);
  border-bottom: 1px solid rgba(255,255,255,0.05);
}
.page-title {
  font-family: var(--font-display);
  font-size: clamp(3rem, 7vw, 5rem);
  line-height: 1;
  color: var(--white);
  letter-spacing: 0.02em;
}
.page-title span { color: var(--copper-bright); }
.page-intro {
  color: var(--gray);
  max-width: 560px;
  line-height: 1.7;
}

.blog-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 1.75rem;
}

.post-card {
  background: var(--navy-light);
  border: 1px solid rgba(255,255,255,0.07);
  border-radius: 10px;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  transition: transform 0.25s, border-color 0.25s, box-shadow 0.25s;
}

.post-card:hover {
  transform: translateY(-4px);
  border-color: rgba(181, 96, 42, 0.35);
  box-shadow: 0 12px 40px rgba(0,0,0,0.35);
}

.post-card--featured {
  grid-column: 1 / -1;
  flex-direction: row;
}

.post-card--featured .post-image {
  width: 45%;
  flex-shrink: 0;
}

.post-card--featured .post-image img {
  height: 100%;
}

.post-image {
  overflow: hidden;
  height: 200px;
}

.post-image img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s;
}

.post-card:hover .post-image img {
  transform: scale(1.05);
}

.post-body {
  padding: 1.5rem;
  display: flex;
  flex-direction: column;
  gap: 0.75rem;
  flex: 1;
}

.post-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 0.4rem;
}

.tag {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: var(--copper-light);
  background: rgba(181, 96, 42, 0.12);
  border: 1px solid rgba(181, 96, 42, 0.25);
  padding: 0.2rem 0.6rem;
  border-radius: 3px;
}

.post-title {
  font-family: var(--font-display);
  font-size: 1.3rem;
  letter-spacing: 0.02em;
  line-height: 1.15;
  color: var(--white);
}

.post-card--featured .post-title {
  font-size: 1.75rem;
}

.post-title a {
  transition: color 0.2s;
}

.post-title a:hover { color: var(--copper-light); }

.post-excerpt {
  color: var(--gray);
  font-size: 0.9rem;
  line-height: 1.65;
  flex: 1;
}

.post-footer {
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-top: 1px solid rgba(255,255,255,0.06);
  padding-top: 0.75rem;
  margin-top: 0.5rem;
}

.post-date {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: var(--gray);
  letter-spacing: 0.05em;
}

.read-more {
  display: flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.82rem;
  font-weight: 600;
  color: var(--copper-light);
  transition: gap 0.2s, color 0.2s;
}

.read-more:hover { gap: 0.6rem; color: var(--copper-bright); }

.empty-state {
  text-align: center;
  padding: 5rem;
  color: var(--gray);
}

.empty-icon { font-size: 3rem; margin-bottom: 1rem; }
.empty-state h2 { color: var(--white); margin-bottom: 0.75rem; }
.empty-state code {
  background: rgba(255,255,255,0.08);
  padding: 0.1rem 0.4rem;
  border-radius: 4px;
  font-family: var(--font-mono);
  font-size: 0.85em;
}

@media (max-width: 900px) {
  .blog-grid { grid-template-columns: 1fr 1fr; }
  .post-card--featured { flex-direction: column; grid-column: auto; }
  .post-card--featured .post-image { width: 100%; }
}

@media (max-width: 600px) {
  .blog-grid { grid-template-columns: 1fr; }
}
</style>
